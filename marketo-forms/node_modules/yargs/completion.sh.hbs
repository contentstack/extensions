###-begin-{{app_name}}-completions-###
#
***REMOVED***yargs command completion script
#
***REMOVED***Installation: {{app_path}} completion >> ~/.bashrc
***REMOVED***   or {{app_path}} completion >> ~/.bash_profile on OSX.
#
_yargs_completions()
{
    local cur_word args type_list

    cur_word="${COMP_WORDS[COMP_CWORD]}"
    args=("${COMP_WORDS[@]}")

    ***REMOVED***ask yargs to generate completions.
    type_list=$({{app_path}} --get-yargs-completions "${args[@]}")

    COMPREPLY=( $(compgen -W "${type_list}" -- ${cur_word}) )

    ***REMOVED***if no match was found, fall back to filename completion
    if [ ${#COMPREPLY[@]} -eq 0 ]; then
      COMPREPLY=( $(compgen -f -- "${cur_word}" ) )
    fi

    return 0
}
complete -F _yargs_completions {{app_name}}
###-end-{{app_name}}-completions-###
