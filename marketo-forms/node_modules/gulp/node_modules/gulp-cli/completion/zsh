***REMOVED***To enable zsh <tab> completion for gulp, add the following line (minus the
***REMOVED***leading #, which is the zsh comment character) to your ~/.zshrc file:
#
***REMOVED***eval "$(gulp --completion=zsh)"

***REMOVED***Enable zsh autocompletion.
function _gulp_completion() {
  ***REMOVED***Grab tasks
  compls=$(gulp --tasks-simple)
  completions=(${=compls})
  compadd -- $completions
}

compdef _gulp_completion gulp
