***REMOVED***Usage:
#
***REMOVED***To enable bash <tab> completion for gulp, add the following line (minus the
***REMOVED***leading #, which is the bash comment character) to your ~/.bashrc file:
#
***REMOVED***eval "$(gulp --completion=bash)"

***REMOVED***Enable bash autocompletion.
function _gulp_completions() {
  ***REMOVED***The currently-being-completed word.
  local cur="${COMP_WORDS[COMP_CWORD]}"
  #Grab tasks
  local compls=$(gulp --tasks-simple)
  ***REMOVED***Tell complete what stuff to show.
  COMPREPLY=($(compgen -W "$compls" -- "$cur"))
}

complete -o default -F _gulp_completions gulp
